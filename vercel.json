{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/admin/(.*)", "dest": "/admin/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
{
  "headers": [
    {
      "source": "/admin/config.yml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/yaml"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/admin/index.html" }
  ]
}